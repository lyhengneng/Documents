							"query": [
								{
									"key": "token",
									"value": "{{token}}"
								},
								{
									"key": "sendID",
									"value": "{{user_id}}"
								},
								{
									"key": "platformID",
									"value": "1"
								},
								{
									"key": "operationID",
									"value": "seq_{{$timestamp}}"
								}
							]
						},
						"description": "Get latest message sequence numbers",
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"reqIdentifier\": 1001,\n\t\"sendID\": \"{{user_id}}\",\n\t\"operationID\": \"op_{{$timestamp}}\",\n\t\"msgIncr\": \"seq_{{$randomInt}}\",\n\t\"data\": \"e30=\"\n}"
						},
						"_postman_pre_request_script": "console.log('Getting sequence numbers...');",
						"_postman_test_script": "try {\n    const response = JSON.parse(pm.response.text());\n    \n    pm.test(\"Response has no errors\", function() {\n        pm.expect(response.errCode).to.eql(0);\n    });\n    \n    pm.test(\"Request identifier is 1001\", function() {\n        pm.expect(response.reqIdentifier).to.eql(1001);\n    });\n    \n    console.log('Sequence response:', response);\n} catch (e) {\n    console.log('Error:', e);\n}"
					}
				},
