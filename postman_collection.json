		{
			"name": "Error Handling Tests",
			"item": [
				{
					"name": "Missing Required Fields",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "ws://localhost:10001/?token={{token}}&sendID={{user_id}}&platformID=1&operationID=error_{{$timestamp}}",
							"protocol": "ws",
							"host": ["localhost"],
							"port": "10001",
							"query": [
								{
									"key": "token",
									"value": "{{token}}"
								},
								{
									"key": "sendID",
									"value": "{{user_id}}"
								},
								{
									"key": "platformID",
									"value": "1"
								},
								{
									"key": "operationID",
									"value": "error_{{$timestamp}}"
								}
							]
						},
						"description": "Test missing required fields (should return error)",
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"reqIdentifier\": 1003\n}"
						},
						"_postman_pre_request_script": "console.log('Testing missing required fields...');",
						"_postman_test_script": "try {\n    const response = JSON.parse(pm.response.text());\n    \n    pm.test(\"Response contains error\", function() {\n        pm.expect(response.errCode).to.not.eql(0);\n    });\n    \n    pm.test(\"Error message is present\", function() {\n        pm.expect(response.errMsg).to.not.be.empty;\n    });\n    \n    console.log('Error response:', response);\n} catch (e) {\n    console.log('Error:', e);\n}"
					}
				},
				{
					"name": "Invalid Message Format",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "ws://localhost:10001/?token={{token}}&sendID={{user_id}}&platformID=1&operationID=invalid_{{$timestamp}}",
							"protocol": "ws",
							"host": ["localhost"],
							"port": "10001",
							"query": [
								{
									"key": "token",
									"value": "{{token}}"
								},
								{
									"key": "sendID",
									"value": "{{user_id}}"
								},
								{
									"key": "platformID",
									"value": "1"
								},
								{
									"key": "operationID",
									"value": "invalid_{{$timestamp}}"
								}
							]
						},
						"description": "Test invalid JSON format (should return error)",
						"body": {
							"mode": "raw",
							"raw": "{invalid json format}"
						},
						"_postman_pre_request_script": "console.log('Testing invalid JSON format...');",
						"_postman_test_script": "try {\n    const response = pm.response.text();\n    \n    pm.test(\"Response indicates error\", function() {\n        pm.expect(response).to.include('error') || pm.expect(response).to.include('Error');\n    });\n    \n    console.log('Invalid JSON response:', response);\n} catch (e) {\n    console.log('Error:', e);\n}"
					}
				},
