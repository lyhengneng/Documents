							"mode": "raw",
							"raw": "{\n\t\"reqIdentifier\": 1003,\n\t\"sendID\": \"{{user_id}}\",\n\t\"operationID\": \"op_{{$timestamp}}\",\n\t\"msgIncr\": \"large_{{$randomInt}}\",\n\t\"data\": \"SGVsbG8gV29ybGQhIFRoaXMgaXMgYSBsYXJnZSBtZXNzYWdlIHRlc3Qu\" \n}"
