		{
			"name": "Compression Tests",
			"item": [
				{
					"name": "Connection with Compression",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "ws://localhost:10001/?token={{token}}&sendID={{user_id}}&platformID=1&operationID=comp_{{$timestamp}}&compression=gzip",
							"protocol": "ws",
