{
	"info": {
		"_postman_id": "openim-websocket-test-collection",
		"name": "OpenIM WebSocket Tests",
		"description": "Complete WebSocket test collection for OpenIM Server msggateway",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Connection Tests",
			"item": [
				{
					"name": "Basic Connection",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "ws://localhost:10001/?token={{token}}&sendID={{user_id}}&platformID=1&operationID=conn_{{$timestamp}}",
							"protocol": "ws",
							"host": ["localhost"],
							"port": "10001",
							"query": [
								{
									"key": "token",
									"value": "{{token}}"
								},
								{
									"key": "sendID",
									"value": "{{user_id}}"
								},
								{
									"key": "platformID",
									"value": "1"
								},
								{
									"key": "operationID",
									"value": "conn_{{$timestamp}}"
								}
							]
						},
						"description": "Test basic WebSocket connection"
					},
					"_postman_pre_request_script": "console.log('Connecting to WebSocket...');\nconsole.log('User ID:', pm.environment.get('user_id'));\nconsole.log('Token:', pm.environment.get('token'));"
				}
			]
		},
		{
			"name": "Message Tests",
			"item": [
				{
					"name": "Send Hello Message",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "ws://localhost:10001/?token={{token}}&sendID={{user_id}}&platformID=1&operationID=msg_{{$timestamp}}",
							"protocol": "ws",
							"host": ["localhost"],
							"port": "10001",
							"query": [
								{
									"key": "token",
									"value": "{{token}}"
								},
								{
									"key": "sendID",
									"value": "{{user_id}}"
								},
								{
									"key": "platformID",
									"value": "1"
								},
								{
									"key": "operationID",
									"value": "msg_{{$timestamp}}"
								}
							]
						},
						"description": "Send a simple Hello World message",
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"reqIdentifier\": 1003,\n\t\"sendID\": \"{{user_id}}\",\n\t\"operationID\": \"op_{{$timestamp}}\",\n\t\"msgIncr\": \"msg_{{$randomInt}}\",\n\t\"data\": \"SGVsbG8gV29ybGQh\"\n}"
						},
						"_postman_pre_request_script": "console.log('Sending Hello message...');",
						"_postman_test_script": "// Parse response\ntry {\n    const response = JSON.parse(pm.response.text());\n    \n    // Validate response\n    pm.test(\"Response has no errors\", function() {\n        pm.expect(response.errCode).to.eql(0);\n    });\n    \n    pm.test(\"Request identifier matches\", function() {\n        pm.expect(response.reqIdentifier).to.eql(1003);\n    });\n    \n    pm.test(\"Response contains data\", function() {\n        pm.expect(response.data).to.exist;\n    });\n    \n    console.log('Response:', response);\n} catch (e) {\n    console.log('Error parsing response:', e);\n}"
					}
				},
				{
					"name": "Get Sequence Numbers",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "ws://localhost:10001/?token={{token}}&sendID={{user_id}}&platformID=1&operationID=seq_{{$timestamp}}",
							"protocol": "ws",
							"host": ["localhost"],
