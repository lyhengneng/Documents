							"mode": "raw",
							"raw": "{\n\t\"reqIdentifier\": 9999,\n\t\"sendID\": \"{{user_id}}\",\n\t\"operationID\": \"op_{{$timestamp}}\",\n\t\"msgIncr\": \"msg_{{$randomInt}}\",\n\t\"data\": \"SGVsbG8=\"\n}"
						},
						"_postman_pre_request_script": "console.log('Testing invalid request identifier...');",
